{
  "name": "trash-card",
  "version": "2.4.7",
  "description": "TrashCard - indicates what type of trash will be picked up next based on your calendar entries 🗑️",
  "keywords": [
    "paper",
    "card",
    "trash",
    "waste",
    "home-assistant",
    "hacs",
    "lovelace",
    "lovelace-custom-card",
    "hassio",
    "frontend",
    "calendar"
  ],
  "private": true,
  "main": "dist/trashcard.js",
  "scripts": {
    "start": "rollup -c --watch --bundleConfigAsCjs",
    "build": "rollup -c --bundleConfigAsCjs",
    "clean": "npx rimraf ./dist",
    "qa": "npm run lint && npm run test",
    "lint": "npx eslint ./src --color",
    "test": "npx jest",
    "start:hass": "docker run --rm -p8123:8123 -v ${PWD}/.hass_dev:/config homeassistant/home-assistant",
    "start:hass-cmd": "docker run --rm -p8123:8123 -v  %cd%/.hass_dev:/config homeassistant/home-assistant"
  },
  "author": "Sven Vetsch (based on work by Florian Triebel)",
  "repository": {
    "type": "git",
    "url": "https://github.com/disenchant/hassio-trash-card"
  },
  "license": "ISC",
  "dependencies": {
    "@material/mwc-select": "0.27.0",
    "@material/mwc-textfield": "0.27.0",
    "color": "4.2.3",
    "lit": "3.3.2",
    "luxon": "3.7.2",
    "memoize-one": "6.0.0",
    "sortablejs": "1.15.7",
    "superstruct": "2.0.2"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.2",
    "@eslint/compat": "^1.4.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@material/mwc-ripple": "0.27.0",
    "@material/tab-bar": "14.0.0",
    "@rollup/plugin-babel": "6.1.0",
    "@rollup/plugin-commonjs": "28.0.9",
    "@rollup/plugin-json": "6.1.0",
    "@rollup/plugin-node-resolve": "15.3.1",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "12.3.0",
    "@types/color": "4.2.1",
    "@types/hammerjs": "2.0.46",
    "@types/jest": "29.5.14",
    "@types/luxon": "3.7.1",
    "@typescript-eslint/eslint-plugin": "8.57.2",
    "@typescript-eslint/parser": "8.57.2",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jest": "29.15.1",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.4.0",
    "home-assistant-js-websocket": "9.6.0",
    "jest": "29.7.0",
    "prettier": "3.8.1",
    "rimraf": "6.1.3",
    "rollup": "4.60.1",
    "rollup-plugin-serve": "1.1.1",
    "ts-jest": "29.4.6",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.57.2"
  },
  "overrides": {
    "lit": "3.3.2"
  },
  "browserslist": "> 0.25%, not dead"
}
